# 1. Advertise the API Catalog
/.well-known/api-catalog
  Content-Type: application/linkset+json

# 2. Link every page to its Markdown alternative
# When an agent visits any HTML page, this tells it a .md version exists
/*
  Link: </:path.md>; rel="alternate"; type="text/markdown"

# 3. Explicitly set content types for your special files
/*.md
  Content-Type: text/markdown; charset=utf-8

# 4. Global security headers (recommended best practice)
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
